      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# IN[0] — список FamilyInstance (или одиночный элемент)\r\nelems = IN[0]\r\nif not isinstance(elems, (list, tuple)):\r\n    elems = [elems]\r\n\r\nids = []\r\nfor e in elems:\r\n    # Разгибаем Dynamo wrapper до реального элемента, если нужно\r\n    obj = getattr(e, 'InternalElement', e)\r\n    if hasattr(obj, 'Id') and hasattr(obj.Id, 'IntegerValue'):\r\n        ids.append(obj.Id.IntegerValue)\r\n    else:\r\n        ids.append(None)\r\n\r\nOUT = ids\r\n",
      "VariableInputPorts": true,
      "Id": "442bbfdbf24b4cd8b4c388e2f8b6521e",
      "Inputs": [
        {
          "Id": "5302ce9e3a9b499491bf777b57483b83",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "6f2b56f9194f45cdbbc9a861b3ad9e14",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария IronPython."
    },
