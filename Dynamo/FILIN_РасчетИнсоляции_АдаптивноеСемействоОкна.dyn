    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "from datetime import datetime, timedelta\r\n\r\n# Входы из Dynamo\r\ntimes_str = IN[0]          # список строк формата \"HH:MM:SS\"\r\nstep_minutes = IN[1]        # шаг в минутах (число)\r\n\r\n# Конвертируем строки в datetime\r\ntimes = [datetime.strptime(t, \"%H:%M:%S\") for t in times_str]\r\n\r\n# Удаляем подряд идущие дубликаты времени\r\ndef remove_consecutive_duplicates(dt_list):\r\n    if not dt_list:\r\n        return dt_list\r\n    out = [dt_list[0]]\r\n    for t in dt_list[1:]:\r\n        if t != out[-1]:\r\n            out.append(t)\r\n    return out\r\n\r\ntimes = remove_consecutive_duplicates(times)\r\n\r\nperiods = []\r\nif times:\r\n    start_time = times[0]\r\n    prev_time = times[0]\r\n    start_idx = 0  # индекс начала периода\r\n\r\n    for idx, current in enumerate(times[1:], start=1):\r\n        delta = current - prev_time\r\n\r\n        # Игнорируем дубликаты (хоть и они уже удалены, на всякий случай)\r\n        if delta == timedelta(0):\r\n            continue\r\n\r\n        if delta == timedelta(minutes=step_minutes):\r\n            prev_time = current\r\n        else:\r\n            # Только если период действительно длился\r\n            if prev_time != start_time:\r\n                periods.append((start_time.time(), prev_time.time()))\r\n            start_time = current\r\n            prev_time = current\r\n            start_idx = idx\r\n\r\n    # последний период\r\n    if prev_time != start_time:\r\n        periods.append((start_time.time(), prev_time.time()))\r\n\r\n# Вывод\r\nOUT = periods\r\n",
      "VariableInputPorts": true,
      "Id": "da62d2694d824602bbb1bbde524a18ab",
      "Inputs": [
        {
          "Id": "2bd486bf14e245728848373942d3b871",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "d17f93fb093d402498da31c95ca1a1ee",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
