    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "Data=IN[0]\r\nOUT=(sum(Data))\r\n",
      "VariableInputPorts": true,
      "Id": "87db62c3b5cd46ee9e6cd2cd146ad037",
      "Inputs": [
        {
          "Id": "145bd377f36c4ff792c4347a4cb10e65",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "9ce56b892f2e46649e82d15cbf06d6fd",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария IronPython."
    },
    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "from datetime import datetime, timedelta\r\n\r\n# Входы из Dynamo\r\ntimes_str = IN[0]          # список строк формата \"HH:MM:SS\"\r\nstep_minutes = IN[1]        # шаг в минутах (число)\r\n\r\n# Конвертируем строки в datetime\r\ntimes = [datetime.strptime(t, \"%H:%M:%S\") for t in times_str]\r\n\r\n# Удаляем подряд идущие дубликаты времени\r\ndef remove_consecutive_duplicates(dt_list):\r\n    if not dt_list:\r\n        return dt_list\r\n    out = [dt_list[0]]\r\n    for t in dt_list[1:]:\r\n        if t != out[-1]:\r\n            out.append(t)\r\n    return out\r\n\r\ntimes = remove_consecutive_duplicates(times)\r\n\r\nperiods = []\r\nif times:\r\n    start_time = times[0]\r\n    prev_time = times[0]\r\n    start_idx = 0  # индекс начала периода\r\n\r\n    for idx, current in enumerate(times[1:], start=1):\r\n        delta = current - prev_time\r\n\r\n        # Игнорируем дубликаты (хоть и они уже удалены, на всякий случай)\r\n        if delta == timedelta(0):\r\n            continue\r\n\r\n        if delta == timedelta(minutes=step_minutes):\r\n            prev_time = current\r\n        else:\r\n            # Только если период действительно длился\r\n            if prev_time != start_time:\r\n                ray_indxs = list(range(start_idx, idx))\r\n                duration = int((prev_time - start_time).total_seconds() / 60) + step_minutes\r\n                periods.append((start_time.time(), prev_time.time(), duration, ray_indxs))\r\n            start_time = current\r\n            prev_time = current\r\n            start_idx = idx\r\n\r\n    # последний период\r\n    ray_indxs = list(range(start_idx, len(times)))\r\n    if prev_time != start_time:\r\n        duration = int((prev_time - start_time).total_seconds() / 60) + step_minutes\r\n        periods.append((start_time.time(), prev_time.time(), duration, ray_indxs))\r\n\r\n# Вывод\r\nOUT = periods\r\n",
      "VariableInputPorts": true,
      "Id": "1184b41596294d0995fc9c022adae359",
      "Inputs": [
        {
          "Id": "1665492adc5f4e78a98a22ecb580361f",
          "Name": "IN[0]",
          "Description": "Input #0",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        },
        {
          "Id": "ebbf4420253c4e228dc3b2da52216cb7",
          "Name": "IN[1]",
          "Description": "Input #1",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Outputs": [
        {
          "Id": "11a338fef6f64cb6b75ef39795b8b400",
          "Name": "OUT",
          "Description": "Результат сценария Python",
          "UsingDefaultValue": false,
          "Level": 2,
          "UseLevels": false,
          "KeepListStructure": false
        }
      ],
      "Replication": "Disabled",
      "Description": "Выполнение встроенного сценария IronPython."
    },
