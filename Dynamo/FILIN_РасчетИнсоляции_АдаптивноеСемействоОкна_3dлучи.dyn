    {
      "ConcreteType": "PythonNodeModels.PythonNode, PythonNodeModels",
      "NodeType": "PythonScriptNode",
      "Code": "# -*- coding: utf-8 -*-\r\n\r\nimport clr\r\n\r\n# Revit API\r\nclr.AddReference('RevitAPI')\r\nclr.AddReference('RevitServices')\r\nfrom Autodesk.Revit.DB import *\r\nfrom RevitServices.Persistence import DocumentManager\r\nfrom RevitServices.Transactions import TransactionManager\r\n\r\ndoc = DocumentManager.Instance.CurrentDBDocument\r\n\r\n# IN[0] – Element(s) from Dynamo (can be from \"Select Model Elements\" or \"Select Model Element\")\r\nelements = UnwrapElement(IN[0])\r\n\r\nif not isinstance(elements, list):\r\n    elements = [elements]\r\n\r\nfamily_instances = []\r\n\r\nfor el in elements:\r\n    if isinstance(el, FamilyInstance):\r\n        family_instances.append(el)\r\n    else:\r\n        family_instances.append(None)  # Not a family instance\r\n\r\n# Output\r\nOUT = family_instances\r\n",
      "VariableInputPorts": true,
      "Id": "471e6511af1d44158781dc354acfe799",
      "Inputs": [
